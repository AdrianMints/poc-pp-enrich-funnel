{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "rewrites": [
    {
      "source": "/",
      "destination": "/prestaprenda-enrich/index.html"
    },
    {
      "source": "/(.*)\\.html",
      "destination": "/prestaprenda-enrich/$1.html"
    },
    {
      "source": "/css/(.*)",
      "destination": "/prestaprenda-enrich/css/$1"
    },
    {
      "source": "/js/(.*)",
      "destination": "/prestaprenda-enrich/js/$1"
    }
  ]
}
